{% comment %}
  Apple-style hero section for portfolio detail pages.

  Parameters:
    eyebrow   – short label above the title, e.g. "AI Engineer · 2024 – Present"
    title     – main display title
    subtitle  – one-sentence description
    meta      – comma-separated pill labels; prefix with "!" for accent style
    tech      – comma-separated technology names
{% endcomment %}
<section class="apple-hero">
  {% if include.eyebrow %}<span class="apple-eyebrow">{{ include.eyebrow }}</span>{% endif %}
  <h1 class="apple-title">{{ include.title }}</h1>
  {% if include.subtitle %}<p class="apple-subtitle">{{ include.subtitle }}</p>{% endif %}

  {% if include.meta %}
  <div class="apple-meta" aria-label="Role and context">
    {% assign meta_items = include.meta | split: "," %}
    {% for item in meta_items %}
      {% if item contains "!" %}
        <span class="apple-pill accent">{{ item | remove: "!" | strip }}</span>
      {% else %}
        <span class="apple-pill">{{ item | strip }}</span>
      {% endif %}
    {% endfor %}
  </div>
  {% endif %}

  {% if include.tech %}
  <div class="apple-tech" aria-label="Technologies">
    {% assign tech_items = include.tech | split: "," %}
    {% for item in tech_items %}
      <span class="apple-chip">{{ item | strip }}</span>
    {% endfor %}
  </div>
  {% endif %}
</section>
